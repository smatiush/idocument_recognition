{"pages": [{"words": {"text": ["COVID-19", "|", "Face", "Mask", "Policy", "The", "Center", "for", "Disease", "Control", "and", "Prevention", "(CDC)", "released", "new", "guidance", "on", "mask", "requirements", "for", "fully", "vaccinated", "individuals", "in", "May", "2020.", "On", "June", "15,", "2021", "Governor", "Andrew", "Cuomo", "lifted", "the", "mask", "mandate", "for", "vaccinated", "New", "Yorkers", "in", "light", "of", "the", "state\u2019s", "vaccination", "rate", "of", "70%.", "Given", "these", "changes,", "Foodlink", "has", "reviewed", "and", "updated", "our", "Face", "Mask", "Policy.", "This", "policy", "is", "effective", "July", "6,", "2021", "and", "is", "intended", "for", "application", "while", "working", "on-site", "at", "Foodlink\u2019s", "headquarters", "on", "Mount", "Read", "Blvd.", "Please", "note:", "Employees", "and", "volunteers", "serving", "in", "public", "facing", "roles", "are", "required", "to", "wear", "masks", "when", "interfacing", "with", "the", "public;", "this", "includes", "serving", "customers", "at", "the", "caf\u00e9", "or", "Curbside", "Market,", "making", "deliveries,", "etc.", "Vaccination", "Status", "Individuals", "are", "fully", "vaccinated", "2", "weeks", "after", "their", "second", "dose", "in", "a", "2-dose", "series,", "such", "as", "the", "Pfizer", "or", "Moderna", "vaccines", "-", "OR", "-", "2", "weeks", "after", "a", "single-dose", "vaccine,", "such", "as", "Johnson", "&", "Johnson\u2019s", "Janssen", "vaccine.", "Unvaccinated", "or", "partially", "vaccinated", "individuals:", "\uf0b7", "All", "employees,", "volunteers", "and", "visitors", "of", "Foodlink", "who", "have", "not", "been", "fully", "vaccinated", "are", "required", "to", "wear", "a", "mask", "at", "all", "times", "and", "should", "continue", "to", "physically", "distance", "from", "others", "during", "work", "hours", "and", "meal", "periods", "while", "unmasked.", "\uf0b7", "This", "requirement", "is", "based", "on", "guidance", "from", "the", "CDC", "as", "well", "as", "OSHA", "and", "is", "intended", "to", "keep", "those", "who", "are", "unvaccinated", "(by", "personal", "choice", "and/or", "health", "related", "reasons)", "healthy", "and", "safe.", "Fully", "vaccinated", "individuals:", "\uf0b7", "All", "employees,", "volunteers", "and", "visitors", "of", "Foodlink", "who", "are", "fully", "vaccinated", "are", "welcome,", "but", "not", "required,", "to", "wear", "a", "mask", "while", "on", "site.", "\uf0b7", "Physically", "distancing", "is", "not", "required,", "but", "encouraged.", "\uf0b7", "Individuals", "in", "this", "category", "who", "would", "like", "to", "go", "mask-free", "while", "on", "site", "must", "complete", "the", "form", "below", "and", "submit", "it", "with", "proof", "of", "vaccination.", "Management", "must", "sign", "off", "on", "the", "form", "before", "it", "is", "submitted", "to", "HR.", "With", "this", "current", "policy", "in", "place,", "under", "no", "circumstances", "will", "an", "individual", "who", "has", "NOT", "provided", "proof", "of", "vaccination", "be", "permitted", "to", "go", "mask-free", "at", "our", "facility.", "NAME:", "________________________________________________", "(copy", "of", "vaccination", "card", "or", "NYS", "excelsior", "pass)", "I", "am", "submitting", "this", "form", "with", "proof", "of", "vaccination", "so", "that", "I", "may", "go", "mask-free", "while", "on", "site", "at", "Foodlink.", "I", "understand", "that", "I", "may", "still", "wear", "my", "mask", "at", "my", "discretion.", "I", "give", "express", "permission", "for", "my", "vaccination", "status", "to", "be", "shared", "with", "Foodlink", "management", "for", "the", "purpose", "of", "upholding", "this", "policy.", "Foodlink", "prohibits", "the", "use", "of", "this", "information", "to", "discriminate", "against", "or", "disparage", "employees,", "volunteers", "or", "visitors.", "________________________________________", "______________", "Employee", "Signature", "Date", "________________________________________", "______________", "Manager", "Signature", "Date", "Completed", "forms", "and", "proof", "of", "vaccination", "must", "be", "submitted", "to", "Human", "Resources", "While", "the", "protection", "of", "health", "information", "afforded", "by", "HIPAA\u2019s", "Privacy", "Rule", "applies", "only", "to", "health", "information", "related", "to", "an", "employer\u2019s", "group", "health", "plan,", "Foodlink", "will", "maintain", "individuals", "privacy", "by", "storing", "these", "records", "in", "a", "secure", "manner", "and", "by", "sharing", "this", "information", "only", "as", "outlined", "above."], "bbox": [[0.672859, 0.048977, 0.090317, 0.017727], [0.768159, 0.048977, 0.010563, 0.017727], [0.783897, 0.048977, 0.042546, 0.017727], [0.831732, 0.048977, 0.050002, 0.017727], [0.886837, 0.048977, 0.0545, 0.017727], [0.058824, 0.098485, 0.027231, 0.013939], [0.090196, 0.098485, 0.049186, 0.013939], [0.143502, 0.098485, 0.021171, 0.013939], [0.168576, 0.098485, 0.055823, 0.013939], [0.228539, 0.098485, 0.054307, 0.013939], [0.286932, 0.098485, 0.027535, 0.013939], [0.31832, 0.098485, 0.080227, 0.013939], [0.402563, 0.098485, 0.041188, 0.013939], [0.447643, 0.098485, 0.062441, 0.013939], [0.5141, 0.098485, 0.031133, 0.013939], [0.549366, 0.098485, 0.066052, 0.013939], [0.619358, 0.098485, 0.019111, 0.013939], [0.642322, 0.098485, 0.03838, 0.013939], [0.684606, 0.098485, 0.099218, 0.013939], [0.787899, 0.098485, 0.021244, 0.013939], [0.813226, 0.098485, 0.031111, 0.013939], [0.848474, 0.098485, 0.078694, 0.013939], [0.058824, 0.11548, 0.078094, 0.013939], [0.14102, 0.11548, 0.013627, 0.013939], [0.158626, 0.11548, 0.032103, 0.013939], [0.194867, 0.11548, 0.041092, 0.013939], [0.240028, 0.11548, 0.021239, 0.013939], [0.265283, 0.11548, 0.033527, 0.013939], [0.302949, 0.11548, 0.022901, 0.013939], [0.329737, 0.11548, 0.036418, 0.013939], [0.370474, 0.11548, 0.069408, 0.013939], [0.443587, 0.11548, 0.057398, 0.013939], [0.5051, 0.11548, 0.052284, 