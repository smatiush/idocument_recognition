{"pages": [{"words": {"text": ["Relational", "Mindfulness", "Agreements", "We", "offer", "the", "following", "agreements*", "to", "ensure", "that", "all", "members", "of", "our", "community", "are", "able", "to", "bring", "their", "whole", "selves", "as", "freely", "and", "safely", "as", "possible", "to", "all", "of", "our", "discussions.", "We", "ask", "that", "you", "reflect", "on", "these", "carefully", "and", "bring", "mindful", "awareness", "of", "these", "intentions", "to", "all", "interactions.", "\u200bBe", "willing", "to", "\u201ctry", "on\u201d", "new", "ideas", "or", "ways", "of", "doing", "things", "that", "might", "not", "be", "what", "you", "prefer", "or", "are", "TRY", "IT", "ON:\u200b", "familiar", "with.", "Approach", "interactions", "seeking", "to", "better", "SEEK", "UNDERSTANDING", "INSTEAD", "OF", "AGREEMENT:\u200b", "understand", "others,", "rather", "than", "convincing", "them", "you\u2019re", "right.", "\u201cI", "don\u2019t", "understand\u201d", "instead", "of", "\u201cI", "disagree\u201d", "helps", "you", "learn", "how", "the", "experience", "of", "others", "differs", "from", "yours.", "Attend", "to", "and", "speak", "about", "your", "own", "experiences", "and", "responses.", "Do", "not", "speak", "PRACTICE", "SELF", "FOCUS:\u200b", "for", "a", "whole", "group", "or", "express", "assumptions", "about", "the", "experience", "of", "others.", "\u200bTry", "to", "understand", "and", "UNDERSTAND", "THE", "DIFFERENCE", "BETWEEN", "INTENT", "AND", "IMPACT:\u200b", "acknowledge", "impact.", "Denying", "the", "impact", "of", "something", "said", "by", "focusing", "on", "\u201cgood", "intentions\u201d", "is", "often", "more", "destructive", "than", "the", "initial", "interaction.", "When", "speaking,", "substitute", "\u201cand\u201d", "for", "\u201cbut.\u201d", "This", "practice", "acknowledges", "and", "PRACTICE", "\u201cBOTH", "/", "AND\u201d:\u200b", "honors", "multiple", "realities.", "Practice", "giving", "skillful,", "non-judgmental", "REFRAIN", "FROM", "BLAMING", "OR", "SHAMING", "SELF", "&", "OTHERS:\u200b", "feedback.", "We", "are", "all", "still", "growing.", "Encourage", "full", "participation", "by", "all", "present.", "Take", "note", "of", "who", "is", "speaking", "and", "MOVE", "UP", "/", "MOVE", "BACK:\u200b", "who", "is", "not.", "If", "you", "tend", "to", "speak", "often,", "consider", "\u201cmoving", "back\u201d", "and", "vice", "versa.", "Try", "to", "avoid", "planning", "what", "you\u2019ll", "say", "as", "you", "listen", "to", "others.", "Listen", "PRACTICE", "MINDFUL", "LISTENING:\u200b", "with", "your", "whole", "self,", "and", "try", "to", "maintain", "awareness", "of", "your", "body", "as", "you", "listen.", "Be", "willing", "to", "be", "surprised,", "to", "learn", "something", "new.", "home", "learnings", "but", "don\u2019t", "identify", "anyone", "other", "than", "yourself,", "now", "or", "later.", "If", "you", "CONFIDENTIALITY:", "\u200bTake", "want", "to", "follow", "up", "with", "anyone", "regarding", "something", "they", "said", "in", "this", "session,", "ask", "first", "and", "respect", "their", "wishes.", "You", "can", "say", "\u201cI", "pass\u201d", "if", "you", "don\u2019t", "wish", "to", "speak.", "If", "someone", "else", "chooses", "to", "pass,", "respect", "RIGHT", "TO", "PASS:\u200b", "their", "wish", "rather", "than", "trying", "to", "change", "their", "mind.", "*", "Adapted", "from", "similar", "agreements", "used", "by", "Visions", "Inc.", "and", "the", "East", "Bay", "Meditation", "Center.", "\u00a9", "Mindful", "Schools", "is", "a", "501(c)(3)", "nonprofit", "organization.", "www.mindfulschools.org"], "bbox": [[0.247549, 0.123906, 0.143343, 0.025246], [0.399973, 0.123906, 0.174868, 0.025246], [0.58392, 0.123906, 0.178461, 0.025246], [0.058824, 0.161154, 0.029243, 0.018936], [0.092698, 0.161154, 0.037558, 0.018936], [0.134889, 0.161154, 0.025777, 0.018936], [0.165297, 0.161154, 0.074182, 0.018936], [0.244111, 0.161154, 0.103099, 0.018936], [0.351842, 0.161154, 0.016078