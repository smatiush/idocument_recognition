{"pages": [{"words": {"text": ["!", "!", "!", "!", "!", "Meeting", "to", "present", "the", "results", "of", "the", "study", "on", "the", "film", "and", "audiovisual", "industry", "in", "Africa", "Wednesday", "2", "June", "2021", "From", "11:00AM", "to", "12:00PM", "(Online)", "Context:", "The", "film", "and", "audiovisual", "industry", "in", "Africa", "continues", "to", "grow", "and", "represents", "great", "economic", "potential", "for", "states.", "During", "the", "Forum", "of", "Ministers", "of", "Culture", "held", "on", "19", "November", "2019,", "within", "the", "framework", "of", "the", "40th", "session", "of", "the", "General", "Conference,", "many", "Member", "States", "of", "the", "Africa", "region", "highlighted", "the", "strategic", "importance", "of", "this", "industry", "to", "achieve", "the", "full", "development", "potential", "of", "the", "continent.", "As", "the", "year", "2021", "has", "been", "declared", "as", "the", "Year", "of", "Arts,", "Culture", "and", "Heritage", "by", "the", "African", "Union", "(AU),", "UNESCO", "in", "collaboration", "with", "the", "AU", "has", "embarked", "on", "a", "year", "of", "celebration", "to", "strengthen", "the", "creative", "economy", "on", "the", "continent", "in", "line", "with", "the", "AU", "Agenda", "2063", "(Aspiration", "5).", "In", "this", "context,", "UNESCO", "has", "undertaken", "a", "study", "on", "the", "film", "and", "audiovisual", "industry", "in", "Africa.", "This", "study", "will", "establish", "a", "roadmap", "to", "support", "the", "development", "of", "this", "strategic", "sector", "in", "Africa", "through", "relevant", "programs.", "Purpose", "of", "the", "meeting:", "In", "November", "2020,", "UNESCO", "launched", "an", "online", "consultation", "with", "the", "54", "States", "of", "the", "Africa", "region", "to", "draw", "a", "clear", "overview", "of", "the", "state", "of", "the", "film", "and", "audiovisual", "industry", "in", "the", "continent.", "A", "total", "of", "36", "countries", "participated", "in", "this", "consultation,", "which", "closed", "on", "11", "February", "2021.", "A", "consultation", "with", "stakeholders", "(private", "sector,", "individuals,", "civil", "society", "organizations)", "was", "also", "undertaken", "in", "parallel.", "In", "order", "to", "carry", "out", "this", "study,", "UNESCO", "called", "on", "a", "team", "of", "consultants", "who", "analyzed", "the", "information", "collected", "and", "identified", "the", "first", "trends", "in", "the", "industry", "on", "the", "continent.", "During", "this", "meeting,", "the", "team", "of", "consultants,", "represented", "by", "Ms.", "Marie", "Lora", "Mungai,", "will", "present", "the", "preliminary", "results", "of", "this", "study.", "This", "meeting", "will", "also", "be", "an", "opportunity", "to", "collect", "comments", "from", "Member", "States", "before", "the", "publication", "of", "the", "report", "entitled", "\"Focus", "on", "the", "film", "industry", "in", "Africa:", "Structural", "reforms", "and", "digital", "transition", "for", "diversity\"", "which", "will", "be", "launched", "on", "September", "2021.", "Participants:"], "bbox": [[0.119809, 0.042638, 0.004102, 0.01566], [0.119809, 0.058602, 0.004102, 0.01566], [0.119809, 0.074567, 0.004102, 0.01566], [0.119809, 0.090531, 0.004102, 0.01566], [0.119809, 0.106495, 0.004102, 0.01566], [0.155438, 0.142798, 0.078033, 0.014254], [0.241386, 0.142798, 0.018822, 0.014254], [0.268129, 0.142798, 0.072325, 0.014254], [0.348372, 0.142798, 0.03043, 0.014254], [0.386709, 0.142798, 0.064143, 0.014254], [0.458768, 0.142798, 0.018224, 0.014254], [0.484974, 0.142798, 0.030426, 0.014254], [0.523344, 0.142798, 0.050987, 0.014254], [0.582259, 0.142798, 0.022671, 0.014254], [0.612866, 0.142798, 0.030426, 0.014254], [0.651236, 0.142798, 0.035909, 0.014254], [0.69507, 0.142798, 0.033801, 0.014254], [0.736807, 0.142798, 0.107742, 0.014254], [0.417155, 0.160187, 0.077919, 0.014254], [0.502986, 0.160187, 0.016605, 0.014254], [0.527511, 0.1601