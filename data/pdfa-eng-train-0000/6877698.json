{"pages": [{"words": {"text": ["EXECUTIVE", "SUMMARY", "The", "push", "is", "on", "to", "complete", "Phase", "1", "and", "open", "the", "new", "parking", "garage", "to", "the", "public", "in", "the", "month", "of", "June!", "Much", "of", "the", "work", "activity", "focus", "has", "evolved", "from", "exterior", "to", "interior", "scope.", "In", "particular,", "the", "parking", "garage", "interior", "mechanical,", "electrical", "and", "plumbing", "(MEP)", "work", "and", "interior", "architectural", "finishes.", "The", "underbuild", "(public)", "work", "inside", "the", "parking", "garage", "continues", "very", "close", "coordination", "with", "the", "overbuild", "(private)", "work", "above", "the", "parking", "garage.", "The", "private", "development", "is", "placing", "concrete", "columns", "and", "slabs", "which", "necessitates", "the", "installation", "of", "temporary", "shoring", "below", "inside", "the", "parking", "garage.", "The", "MEP", "and", "architectural", "finishes", "within", "the", "garage", "are", "installed", "both", "before", "the", "shoring", "is", "installed", "and", "after", "the", "shoring", "is", "removed.", "Highlights", "this", "month:", "Safety", "1,362", "workers", "attended", "the", "Construction", "Manager\u2019s", "jobsite", "safety", "orientation", "program", "to", "date,", "and", "have", "worked", "over", "219,000", "hours", "on", "site", "through", "April", "30,", "2010,", "without", "a", "lost", "time", "accident.", "The", "Construction", "Manager", "hosted", "a", "jobsite", "safety", "celebration", "lunch", "for", "the", "workers", "on", "April", "22,", "2010.", "Inclusion", "The", "overall", "participation", "for", "Small", "Business", "Enterprises", "(SBEs)", "for", "construction", "is", "31.5%,", "exceeding", "the", "30%", "goal.", "Minority", "Business", "Enterprise", "participation", "(MBE)", "for", "construction", "is", "9.7%", "and", "Women", "Business", "Enterprise", "(WBE)", "participation", "is", "3.3%.", "The", "combined", "minority/female", "workforce", "participation", "goal", "is", "22%", "and", "the", "actual", "is", "19.19%.", "Budget", "The", "Phase", "1", "of", "the", "IDMA", "remains", "within", "budget.", "The", "Banks", "Phase", "1", "Construction", "Budget", "cost-", "tracking", "tool", "includes", "the", "latest", "status", "of", "approved", "change", "orders", "and", "potential", "change", "orders", "sorted", "by", "collective", "Bid", "Package.", "Construction", "budget", "status", "information", "is", "contained", "within", "the", "Budget", "Section", "of", "this", "monthly", "report.", "The", "Phase", "2A", "budget", "was", "presented", "to", "the", "Joint", "Banks", "Steering", "Committee", "(JBSC)", "on", "April", "22,", "2010,", "and", "will", "be", "presented", "to", "Hamilton", "County", "and", "the", "City", "of", "Cincinnati", "in", "early", "May", "2010.", "Schedule", "The", "Phase", "1", "of", "the", "Public", "Infrastructure", "remains", "on", "schedule.", "Construction", "schedule", "status", "information", "is", "contained", "within", "the", "Schedule", "Section", "of", "this", "monthly", "report.", "The", "remaining", "BP5", "punch", "list", "work", "continued", "through", "April", "and", "will", "be", "complete", "in", "early", "May;", "when", "complete", "BP5", "will", "be", "ready", "for", "close", "out.", "BP6", "contractor", "continued", "structure", "work", "completing", "Block", "16", "structure", "and", "continuing", "into", "Block", "20.", "The", "utility", "vault", "work", "completed", "in", "April", "and", "the", "garage", "switched", "from", "temporary", "to", "permanent", "power", "at", "the", "end", "of", "the", "month.", "BP8", "contractor", "continues", "with", "MEP", "installation", "in", "Blocks", "26", "and", "16.", "The", "private", "development", "construction", "manager,", "Brasfield", "&", "Gorrie,", "continued", "building", "columns", "and", "placing", "slabs", "in", "Block", "26", "and", "began", "building", "columns", "and", "placing", "slabs", "in", "Block", "16.", "Parks", "first", "construction", "package", "(Block", "21)", "was", "opened", "in", "April", "and", "will", "be", "awarded", "in", "early", "May", "and", "their", "second", "package", "(Block", "20)", "began", "advertisement", "late", "in", "the", "month", "and", "will", "award", "by", "early", "June.", "BP", "13", "work", "was", "completed", "by", "the", "end", "of", "April;", "both", "the", "new", "water", "service", "through", "the", "Transit", "Center", "into", "Block", "26", "and", "the", "sanitary", "sewer", "work", "in", "Ted", "Berry", "Way", "are", "fully", "installed.", "BP9", "(new", "Mehring)", "work", "continued", "in", "April", "and", "the", "archaeological", "dig", "in", "Lot", "D", "began.", "BP10", "signage", "mock", "ups", "arrived", "in", "April", "and", "the", "garage", "signage", "will", "be", "installed", "throughout", "May.", "BP11", "is", "scheduled", "to", "be", "opened", "and", "awarded", "in", "early", "May.", "*Please", "see", "Appendix", "C,", "Glossary", "of", "Acronyms,", "for", "an", "explanation", "of", "the", "acronyms", "contained", "within."], "bbox": [[0.176953, 0.17044, 0.126741, 0.021366], [0.31006, 0.17044, 0.11307, 0.021366], [0.206445, 0.208894, 0.025537, 0.012576], [0.236134, 0.208894, 0.03081, 0.012576], [0.270934, 0.208894, 0.010873, 0.012576], [0.285877, 0.208894, 0.016417, 0.012576], [0.306341, 0.208894, 0.012696, 0.012576], [0.323264, 0.208894, 0.059986, 0.012576], [0.387413, 0.208894, 0.038314, 0.012576], [0.429892, 0.208894, 0.008159, 0.012576], [0.442278, 0.208894, 0.023516, 0.012576], [0.47002, 0.208894, 0.031953, 0.012576], [0.50602, 0.208894, 0.019858, 0.012576], [0.530041, 0.208894, 0.027337, 0.012576], [0.561341, 0.208894, 0.050246, 0.012576], [0.615634, 0.208894, 0.043651, 0.012576], [0.663449, 0.208894, 0.012696, 0.012576], [0.680372, 0.208894, 0.019858, 0.012576], [0.704393, 0.208894, 0.040909, 0.012576], [0.749466, 0.208894, 0.012876, 0.012576], [0.766389, 0.208894, 0.0