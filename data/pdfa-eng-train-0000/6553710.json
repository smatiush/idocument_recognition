{"pages": [{"words": {"text": ["Department", "Request", "to", "Defer", "Graduate", "Start", "Term", "Graduate", "Departments", "may", "defer", "their", "graduate", "students", "up", "to", "one", "year", "following", "the", "original", "term", "of", "admission", "due", "to", "extenuating", "circumstances.", "Graduate", "students", "must", "be", "officially", "admitted", "to", "a", "graduate", "program", "at", "the", "University", "of", "Utah", "before", "The", "Office", "of", "Admissions", "will", "the", "deferment", "request.", "Deferment", "requests", "are", "subject", "to", "department/program", "consider", "approval.", "Please", "note", "that", "consideration", "beyond", "one", "year", "requires", "the", "submission", "of", "a", "new", "application", "and", "application", "fee.", "Only", "one", "deferment", "request", "per", "unique", "application", "will", "be", "processed.", "This", "form", "may", "not", "be", "used", "to", "recommend", "a", "student", "to", "a", "different", "program-", "the", "submission", "of", "a", "new", "application", "and", "program-specific", "materials", "for", "that", "new", "program", "will", "be", "required.", "To", "request", "a", "deferment,", "please", "complete", "the", "\u201cGraduate", "Student", "Information\u201d", "section", "with", "the", "student's", "information.", "Once", "all", "fields", "have", "been", "completed,", "please", "forward", "the", "form", "to", "the", "University", "of", "Utah", "Office", "of", "Admissions", "for", "processing", "by", "the", "first", "day", "of", "the", "original", "admit", "term.", "By", "submitting", "this", "form,", "the", "department", "agrees", "to", "the", "following", "conditions", "and", "confirms", "that", "the", "information", "has", "been", "discussed", "with", "the", "student.", "Only", "deferment", "requests", "up", "to", "one", "year", "following", "the", "original", "term", "of", "\u2022", "admission", "will", "be", "considered.", "The", "deadline", "for", "the", "department", "to", "submit", "this", "form", "is", "the", "first", "day", "of", "classes", "\u2022", "of", "the", "student's", "original", "admit", "term.", "Late", "deferment", "requests", "will", "not", "be", "accepted.", "Once", "the", "deferment", "request", "has", "been", "approved,", "a", "deferment", "reversal", "to", "the", "\u2022", "student's", "original", "admit", "term", "will", "not", "be", "granted.", "Each", "student", "is", "entitled", "to", "a", "single", "deferment", "request.", "Subsequent", "deferrals", "\u2022", "will", "not", "be", "accepted", "and", "will", "require", "the", "student", "to", "reapply", "for", "a", "future", "term.", "Students", "whose", "deferment", "requests", "have", "been", "approved", "will", "receive", "a", "formal", "letter", "from", "the", "Office", "of", "Admissions.", "Information", "Graduate", "Student", "Full", "Name:", "Student", "ID", "(uNID):", "Student", "Email:", "Graduate", "Program:", "Term:", "Admit", "Requested", "Deferment", "Term:", "By", "signing", "and", "submitting", "this", "request", "for", "deferment,", "the", "department", "agrees", "to", "the", "specifications", "listed", "above", "and", "the", "student", "has", "intends", "to", "attend", "the", "University", "of", "Utah", "and", "agreed", "to", "the", "following", "conditions:", "\u2022", "Enrollment", "at", "another", "university", "during", "the", "deferment", "period", "is", "not", "permitted", "unless", "prior", "approval", "is", "given", "by", "your", "academic", "department", "at", "the", "University", "of", "Utah.", "The", "student", "the", "the", "student", "\u2022", "must", "notify", "academic", "department", "at", "the", "University", "of", "Utah", "if", "a", "becomes", "matriculated", "student", "at", "another", "institution", "during", "the", "deferment", "period.", "the", "student's", "their", "\u2022", "The", "University", "of", "Utah", "retains", "the", "right", "to", "terminate", "matriculation", "into", "the", "student", "graduate", "program", "if", "decides", "to", "matriculate", "into", "a", "graduate", "program", "at", "a", "different", "institution.", "the", "Failure", "to", "meet", "these", "terms", "may", "result", "in", "the", "revocation", "of", "admission.", "In", "such", "a", "case,", "student", "will", "need", "to", "reapply", "for", "a", "future", "term."], "bbox": [[0.281314, 0.007919, 0.108941, 0.016927], [0.395706, 0.007919, 0.077353, 0.016927], [0.47851, 0.007919, 0.018507, 0.016927], [0.502471, 0.007919, 0.050121, 0.016927], [0.558039, 0.007919, 0.086081, 0.016927], [0.649569, 0.007919, 0.044667, 0.016927], [0.699686, 0.007919, 0.047944, 0.016927], [0.139899, 0.038872, 0.07362, 0.015516], [0.218137, 0.038872, 0.101003, 0.015516], [0.323761, 0.038872, 0.033577, 0.015516], [0.361959, 0.038872, 0.040211, 0.015516], [0.406791, 0.038872, 0.034208, 0.015516], [0.445619, 0.038872, 0.06963, 0.015516], [0.519868, 0.038872, 0.066626, 0.015516], [0.591235, 0.038872, 0.019802, 0.015516], [0.615655, 0.038872, 0.014805, 0.015516], [0.635078, 0.038872, 0.029607, 0.015516], [0.669304, 0.038872, 0.034396, 0.015516], [0.708407, 0.038872, 0.068418, 0.015516], [0.781443, 0.038872, 0.024611, 0.015516], [0.810672, 0.038872, 0.056617, 0.015516], [0.139899, 0.055539, 0.035384, 0.015516], [0.179904, 0.055539, 0.014799, 0.015516], [0.199327, 0.055539, 0.0794, 0.015516], [0.283345, 0.055539, 0.029607, 0.015516], [0.31757, 0.055539, 0.014805, 0.015516], [0.336993, 0.055539, 0.091048, 0.015516], [0.43266, 0.055539, 0.117404, 0.015516], [0.554835, 0.055539, 0.07362, 0.015516], [0.633073, 0.055539, 0.066626, 0.015516], [0.70433, 0.055539, 0.038402, 0.015516], [0.747356, 0.055539, 0.019802, 0.015516], [0.771776, 0.055539, 0.062224, 0.015516], [0.139899, 0.072206, 0.067617, 0.015516], [0.212134, 0.072206, 0.014805, 0.015516], [0.231557, 0.072206, 0.009996, 0.015516], [0.246172, 0.072206, 0.06963, 0.015516], [0.32042, 0.072206, 0.065789, 0.015516], [0.39083, 0.072206, 0.014799, 0.015516], [0.410253, 0.072206, 0.0246