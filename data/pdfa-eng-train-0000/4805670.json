{"pages": [{"words": {"text": ["Code", "of", "Conduct", "Story", "Factory", "provides", "an", "open,", "welcoming", "and", "safe", "environment", "for", "all", "young", "people,", "staff", "and", "volunteers", "participating", "in", "our", "programs.", "Its", "aim", "is", "to", "foster", "the", "development", "of", "writing", "skills", "and", "creativity", "in", "marginalised", "young", "people.", "At", "all", "times", "during", "Story", "Factory", "activities", "and", "when", "working", "for", "or", "representing", "Story", "Factory,", "staff", "and", "volunteers", "will:", "\u25cf", "treat", "people", "with", "respect,", "including", "staff,", "volunteers,", "young", "people,", "parents", "and", "teachers;", "\u25cf", "act", "honestly", "and", "with", "integrity;", "\u25cf", "act", "as", "positive", "role", "models", "to", "young", "people;", "\u25cf", "set", "and", "obey", "clear", "boundaries", "about", "appropriate", "behaviour", "with", "young", "people", "(see", "details", "below);", "\u25cf", "follow", "the", "Child-safe", "Child-friendly", "Policy;", "\u25cf", "comply", "with", "the", "Workplace", "Behaviour", "Policy;", "\u25cf", "only", "conduct", "tutoring", "under", "the", "direct", "supervision", "of", "a", "Story", "Factory", "representative", "who", "has", "satisfied", "a", "Working", "with", "Children", "Check", "and", "National", "Police", "Check;", "\u25cf", "report", "and", "act", "on", "complaints", "and/or", "any", "instances", "of", "inappropriate", "behaviour,", "breach", "of", "policy", "or", "suspected", "or", "observed", "abuse,", "by", "immediately", "notifying", "a", "Storyteller", "or", "other", "Story", "Factory", "staff", "member.", "Staff", "and", "volunteers:", "\u25cf", "will", "not", "develop", "any", "\u2018special\u2019", "relationships", "with", "children", "that", "could", "be", "seen", "as", "favouritism,", "such", "as", "the", "offering", "of", "gifts", "or", "special", "treatment;", "\u25cf", "will", "not", "do", "things", "of", "a", "personal", "nature", "that", "a", "child", "can", "do", "for", "themselves,", "such", "as", "going", "to", "the", "toilet", "or", "changing", "clothes,", "and", "if", "a", "child", "needs", "such", "help,", "staff", "or", "volunteers", "will", "seek", "a", "family", "member", "or", "accredited", "carer", "to", "help", "them;", "\u25cf", "will", "not", "use", "personal", "phones", "or", "other", "electronic", "devices", "during", "workshops;", "\u25cf", "will", "not", "contact", "students", "outside", "of", "workshops,", "either", "in", "person", "or", "by", "phone,", "email,", "social", "media", "or", "any", "other", "electronic", "medium;", "\u25cf", "will", "not", "do", "anything,", "while", "providing", "their", "services,", "that", "may", "bring", "Story", "Factory", "into", "disrepute;", "\u25cf", "accept", "there", "may", "be", "risks", "associated", "with", "providing", "their", "services", "but", "agree", "they", "will", "not", "do", "anything", "to", "unreasonably", "compromise", "their", "own", "safety", "or", "the", "safety", "of", "others;", "\u25cf", "will", "participate", "in", "all", "identity", "verification", "checks,", "background", "security", "checks", "and", "other", "security", "checks", "(which", "may", "include", "inspecting", "their", "personal", "property)", "prior", "to", "their", "entry", "to", "and", "departure", "from", "any", "Story", "Factory", "activity", "or", "premises,", "and", "prior", "to", "their", "provision", "of", "any", "services", "\u2013", "including", "completing", "a", "Working", "With", "Children", "Check", "and", "National", "Police", "Check;", "\u25cf", "will", "do", "anything", "required", "by", "law", "or", "Story", "Factory", "relating", "to", "the", "protection", "of", "children", "and", "abide", "by", "Story", "Factory\u2019s", "policies", "and", "guidelines", "for", "the", "safety", "of", "children", "as", "outlined", "in", "Story", "Factory\u2019s", "Child-safe", "Child-friendly", "Policy,", "this"