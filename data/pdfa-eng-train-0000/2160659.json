{"pages": [{"words": {"text": ["Woolworths", "Corio", "to", "complete", "upgrade", "for", "a", "better", "shopping", "experience", "Monday,", "10", "August", "2015:", "Shoppers", "in", "the", "Corio", "area", "will", "soon", "enjoy", "a", "revamped", "Woolworths", "supermarket,", "as", "the", "$2", "million,", "two", "month", "refurbishment,", "comes", "to", "completion.", "The", "upgrades", "to", "the", "store", "will", "provide", "enhanced", "choice", "and", "convenience", "for", "customers", "from", "Wednesday,", "12", "August", "and", "include", "an", "improved", "delicatessen,", "and", "the", "new", "painting", "and", "internal", "signage", "throughout", "will", "help", "shoppers", "get", "around", "the", "store.", "The", "layout", "for", "the", "checkout", "area", "and", "additional", "self\u2010service", "checkouts", "has", "also", "been", "improved", "to", "ensure", "customers", "can", "pay", "for", "their", "items", "quickly", "and", "get", "on", "with", "their", "day.", "The", "new", "supermarket", "design", "also", "includes", "the", "relocation", "of", "the", "Liquor", "retailer", "BWS", "just", "next", "door.", "In", "addition,", "customers", "can", "expect", "to", "see", "further", "improvements", "in", "the", "coming", "months", "with", "a", "brand", "new", "fit", "out", "of", "the", "produce", "and", "bakery", "departments.", "Woolworths", "Corio", "Store", "Manager,", "Matt", "Pickering,", "said", "the", "store", "has", "been", "a", "part", "of", "the", "local", "community", "since", "it", "opened", "a", "decade", "ago.", "\u201cWe", "are", "delighted", "our", "local", "Woolworths", "store", "has", "been", "upgraded,", "creating", "one", "of", "Australia\u2019s", "most", "modern", "supermarkets.", "The", "investment", "will", "deliver", "a", "supermarket", "local", "residents", "can", "continue", "to", "be", "proud", "of", "and", "support.", "\u201cThese", "improvements", "will", "enhance", "our", "customers\u2019", "shopping", "experience", "as", "they", "pick", "up", "fresh", "Australian", "produce", "and", "meat,", "inspiring", "meal", "ideas,", "a", "wide", "choice", "of", "healthy", "options", "and", "a", "huge", "range", "of", "grocery", "items", "at", "great", "prices,\u201d", "Matt", "said.", "Customers", "can", "visit", "the", "revamped", "store", "during", "the", "usual", "trading", "hours", "of", "7am", "to", "10pm,", "seven", "days", "a", "week.", "The", "investment", "is", "part", "of", "a", "wider", "refurbishment", "program", "across", "Victoria,", "with", "around", "10", "supermarkets", "undergoing", "significant", "upgrades", "or", "extensions", "for", "the", "remainder", "of", "2015.", "\u2010", "Ends", "\u2010", "For", "further", "information", "please", "contact", "Woolworths", "Media", "Relations", "on", "ph", "(02)", "8885", "1033."], "bbox": [[0.092863, 0.214115, 0.138535, 0.019026], [0.237474, 0.214115, 0.05925, 0.019026], [0.302819, 0.214115, 0.023761, 0.019026], [0.332678, 0.214115, 0.105124, 0.019026], [0.443822, 0.214115, 0.092518, 0.019026], [0.542338, 0.214115, 0.032559, 0.019026], [0.580867, 0.214115, 0.013291, 0.019026], [0.600226, 0.214115, 0.069774, 0.019026], [0.676072, 0.214115, 0.102281, 0.019026], [0.784362, 0.214115, 0.12287, 0.019026], [0.047697, 0.252523, 0.068674, 0.01304], [0.121716, 0.252523, 0.018735, 0.01304], [0.145724, 0.252523, 0.054156, 0.01304], [0.205219, 0.252523, 0.042619, 0.01304], [0.253125, 0.252523, 0.070134, 0.01304], [0.328656, 0.252523, 0.013921, 0.01304], [0.347922, 0.252523, 0.025008, 0.01304], [0.378279, 0.252523, 0.04007, 0.01304], [0.423767, 0.252523, 0.033263, 0.01304], [0.462391, 0.252523, 0.025898, 0.01304], [0.493652, 0.252523, 0.036407, 0.01304], [0.535412, 0.252523, 0.041418, 0.01304], [0.582193, 0.252523, 0.008839, 0.01304], [0.596421, 0.252523, 0.076103, 0.01304], [0.677802, 0.252523, 0.092681, 0.01304], [0.775921, 0.252523, 0.100704, 0.01304], [0.882011, 0.252523, 0.016092, 0.01304], [0.903492, 0.252523, 0.025008, 0.01304], [0.933848, 0