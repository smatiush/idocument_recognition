, 27], [35, 54], [35, 81], [35, 108], [35, 135], [35, 162], [35, 189], [35, 216], [35, 243], [36, 0], [36, 27], [36, 54], [36, 81], [37, 0], [37, 27], [37, 54], [37, 81], [37, 108], [37, 135], [37, 162], [37, 189], [37, 216], [38, 0], [38, 27], [38, 54], [38, 81], [38, 108], [38, 135], [38, 162], [38, 189], [38, 216], [38, 243], [39, 0], [39, 27], [39, 54], [40, 0], [40, 27], [40, 54], [40, 81], [40, 108], [40, 135], [40, 162], [40, 189], [40, 216], [40, 243], [40, 270], [40, 297], [41, 0], [41, 27], [41, 54], [41, 81], [42, 0], [42, 27], [42, 54], [42, 81], [42, 108], [42, 135], [42, 162], [42, 189], [43, 0], [43, 27], [43, 54], [43, 81], [43, 108], [43, 135], [43, 162], [43, 189], [43, 216], [43, 243], [43, 270], [43, 297], [43, 324], [43, 351], [43, 378], [43, 405], [43, 432], [43, 459], [43, 486], [43, 513], [44, 0], [44, 27], [44, 54], [44, 81]]}, "lines": {"text": ["tunnel tying machine TGM 350", "Meat presentation better and", "much quicker than done by hand.", "This tunnel tying machine does", "away with the tiresome hand bin-", "ding with meat twine. Whether", "meat, fish or poultry, with or wit-", "hout filling. The t.g.m.350 2003", "guarantees optimal binding results", "and an attractive appearance of", "your product even for irregular", "cuts of meat.", "The tunnel concept ensures a con-", "tinuous flow of material. Even long", "roasts do not need to be turned", "round in order to bind them com-", "pletely.", "Due to the knotting after each", "loop, a simple portioning of the", "roasts is possible without the twine", "fraying.", "The T.G.M.350 automatic even", "does the job automatically.", "Ficeleuse", "Touwmachine", "Meat tying machine \u2022 low maintenance simple", "layout of components make Umschn\u00fcrungsmaschine", "maintenance easy", "\u2022 24Vplc control circuit with", "auto matic reverse cut-off", "\u2022 clutch less braking motor", "\u2022 Toggle switch for single and", "technical info double binding mounted on", "4 casters for mobility", "\u2022 Tunnel diameter: 320x300mm \u2022 can be used for the widest", "\u2022 Performance (single): Up to 60 variety of dimension and", "bindings/min types of meat", "\u2022 Performance (double): 50 bindings/min \u2022 Stainless steel construction", "\u2022 Power requirements: 50/60 Hz, 230V \u2022 Water proof encapsulated", "24V-PLC electric components", "\u2022 Weight circa 120 kg \u2022 can be used in wet areas", "Martin Weinert Maschinenbau GmbH", "Am Eisweiher 10 \u2022 D 74821 Mosbach WEINERT", "fon: +49 (0) 6261 - 1 80 74 22 \u2022 fax: +49 (0) 6261 - 1 80 74 23 MASCHINENBAU", "CNC FERTIGUNG eMail: martin.weinert@mweinert.de"], "bbox": [[0.123289, 0.023774, 0.797494, 0.051399], [0.091565, 0.084616, 0.35125999999999996, 0.017323], [0.091565, 0.101721, 0.341857, 0.017323], [0.091565, 0.135929, 0.351259, 0.017323], [0.091565, 0.153034, 0.351239, 0.017323], [0.091565, 0.170138, 0.35126999999999997, 0.017323], [0.091565, 0.187243, 0.351245, 0.017323], [0.091565, 0.204347, 0.35126199999999996, 0.017323], [0.091565, 0.221452, 0.351259, 0.017323], [0.091565, 0.238556, 0.35124799999999995, 0.017323], [0.091565, 0.25566, 0.351258, 0.017323], [0.091565, 0.272765, 0.13425199999999998, 0.017323], [0.091565, 0.306973, 0.351253, 0.017323], [0.091565, 0.324078, 0.351244, 0.017323], [0.091565, 0.341182, 0.351266, 0.017323], [0.091565, 0.358287, 0.35124500000000003, 0.017323], [0.091565, 0.375391, 0.072975, 0.017323], [0.091565, 0.4096, 0.351271, 0.017323], [0.091565, 0.426704, 0.351251, 0.017323], [0.091565, 0.443809, 0.351235, 0.017323], [0.091565, 0.460913, 0.077394, 0.017323], [0.091565, 0.495122, 0.351259, 0.017323], [0.091565, 0.512226, 0.274308, 0.017323], [0.51892, 0.522693, 0.07708800000000005, 0.017239], [0.51892, 0.542413, 0.11630099999999999, 0.017239], [0.51892, 0.562132, -0.12258400000000008, 0.017323], [0.152041, 0.580643, 0.5736870000000001, 0.017323], [0.152041, 0.597748, 0.183781, 0.017323], [0.091565, 0.614852, 0.323662, 0.017323], [0.152041, 0.631957, 0.2638