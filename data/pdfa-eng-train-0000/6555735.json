{"pages": [{"words": {"text": ["Mexico", "City,", "05th", "March", "2021", "\u2013", "REQUEST", "FOR", "INFORMATION", "RFI/2021/002", "POTENTIAL", "BUYERS", "FOR", "FLEET", "OF", "AIRCRAFT", "OF", "THE", "MEXICAN", "GOVERNMENT", "Under", "the", "Specific", "Agreement,", "signed", "between", "the", "Government", "of", "the", "United", "States", "of", "Mexico,", "through", "the", "Banco", "Nacional", "de", "Obras", "y", "Servicios", "P\u00fablicos,", "S.N.C.", "Instituci\u00f3n", "de", "Banca", "de", "Desarrollo", "(BANOBRAS),", "and", "the", "United", "Nations", "Office", "for", "Project", "Services", "(UNOPS)", "has", "been", "developing", "the", "preparatory", "acts", "for", "the", "next", "tender", "for", "the", "sale", "of", "aircraft", "owned", "by", "the", "Mexican", "Government,", "among", "which", "is", "the", "preparation", "of", "a", "market", "study", "to", "identify", "potential", "bidders", "and", "estimate", "the", "market", "prices", "of", "aircraft", "based", "on", "preliminary", "estimates", "value.", "In", "this", "sense,", "people", "and", "companies", "interested", "in", "buying", "one", "or", "more", "aircraft,", "which", "are", "specified", "in", "the", "document", "attached", "to", "this", "invitation", "as", "to", "register", "and", "express", "their", "interest,", "accordance", "with", "the", "Annex", "1,", "following", "procedure:", "\u2022", "This", "invitation", "is", "open", "to", "national", "and", "foreign", "individuals", "and", "companies", "interested,", "who", "Participants:", "are", "interested", "in", "buying", "one", "or", "more", "aircraft", "included", "in", "(Note:", "This", "process", "is", "not", "open", "to", "Annex", "1.", "press).", "\u2022", "The", "interested", "in", "participating", "in", "this", "request", "for", "information", "(RFI)", "should", "download", "the", "Announcement:", "documents", "using", "the", "United", "Nations", "global", "portal", "for", "suppliers", "(UNGM)", "at", "the", "following", "link:", "ht