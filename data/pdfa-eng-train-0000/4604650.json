{"pages": [{"words": {"text": ["COVID", "Vaccination", "Requirement", "for", "Residential", "Students", "and", "Student-Athletes", "As", "conditions", "evolve", "over", "the", "summer,", "USJ", "will", "continue", "to", "update", "policies", "and", "procedures", "related", "to", "COVID-19.", "Given", "recent", "CDC", "guidelines", "for", "higher", "education,", "USJ", "is", "implementing", "a", "COVID", "vaccination", "requirement", "for", "all", "student-athletes", "and", "students", "who", "will", "live", "in", "on-campus", "housing.", "These", "students", "must", "submit", "proof", "of", "full", "vaccination", "by", "August", "15,", "2021,", "by", "completing", "this", "form", "and", "providing", "an", "image", "of", "their", "vaccine", "card", "(download", "Microsoft", "Power", "Apps", "to", "access", "the", "form", "on", "mobile", "devices).", "To", "ensure", "full", "vaccination", "by", "August", "15,", "student-", "athletes", "and", "residential", "students", "should", "begin", "the", "vaccination", "process", "by", "July", "1.", "The", "vaccine", "requirement", "may", "be", "extended", "to", "other", "students", "over", "the", "next", "few", "weeks,", "so", "it", "is", "recommended", "that", "all", "students", "get", "vaccinated", "as", "soon", "as", "possible.", "Students", "who", "submit", "verification", "will", "be", "issued", "an", "\u201cI", "am", "COVID", "Vaxxed", "at", "USJ\u201d", "bracelet.", "Prior", "to", "issuing", "a", "bracelet,", "Student", "Health", "Services", "(SHS)", "will", "verify", "the", "submitted", "information", "and", "send", "a", "confirmation", "email.", "Once", "the", "confirmation", "email", "has", "been", "received,", "students", "may", "obtain", "a", "bracelet", "by", "visiting", "SHS", "during", "office", "hours", "in", "their", "new", "office", "located", "in", "The", "Beekley", "Center", "for", "Student", "Health", "and", "Wellness", "on", "the", "first", "floor", "of", "the", "O\u2019Connell", "Athletic", "Center.", "Office", "hours", "\u2013", "\u2013", "are", "Monday", "Friday,", "8:30", "a.m.", "4:30", "p.m.,", "and", "masks", "are", "required", "for", "entry.", "Bracelets", "will", "also", "be", "available", "during", "special", "hours", "on", "campus", "move", "in", "days.", "Students", "who", "are", "confirmed", "as", "fully", "vaccinated", "will", "no", "longer", "have", "to", "complete", "the", "Daily", "Attestation", "form", "when", "utilizing", "USJ", "Wi-Fi.", "If", "they", "are", "identified", "as", "a", "close", "contact", "to", "someone", "who", "tests", "positive,", "but", "they", "are", "not", "symptomatic", "themselves,", "they", "will", "not", "be", "required", "to", "quarantine", "or", "be", "tested.", "When", "on", "campus,", "employees", "and", "students", "wearing", "this", "bracelet", "will", "not", "be", "required", "to", "wear", "masks", "indoors", "except", "to", "enter", "the", "Gengras", "Center,", "the", "School", "for", "Young", "Children,", "and", "Student", "Health", "Services.", "Employees", "and", "students", "who", "are", "not", "wearing", "this", "bracelet", "must", "continue", "wearing", "masks", "at", "all", "times", "while", "indoors", "on", "campus,", "unless", "alone", "in", "a", "private", "office,", "and", "must", "wear", "a", "mask", "outdoors", "when", "in", "the", "vicinity", "of", "the", "Gengras", "Center", "or", "School", "for", "Young", "Children.", "Students", "in", "lab", "or", "clinical", "courses", "may", "be", "asked", "to", "wear", "a", "mask,", "regardless", "of", "vaccination", "status,", "based", "upon", "curricular", "requirements.", "Students", "with", "questions", "or", "who", "are", "experiencing", "difficulties", "submitting", "the", "form", "should", "contact", "Student", "Health", "Services", "at", "860.231.5530", "or", "healthservices@usj.edu."], "bbox": [[0.117688, 0.192894, 0.065569, 0.020985], [0.188276, 0.192894, 0.099902, 0.020985], [0.293198, 0.192894, 0.109804, 0.020985], [0.407904, 0.192894, 0.025039, 0.020