{"pages": [{"words": {"text": ["Supreme", "Court", "of", "Illinois", "OF", "THE", "ADMINISTRATIVE", "OFFICE", "ILLINOIS", "COURTS", "222", "North", "LaSalle", "Street,", "13th", "Floor", "Marcia", "M.", "Meis", "Chicago,", "IL", "60601", "Director", "Phone:", "(312)", "793-6165", "mmeis@illinoiscourts.gov", "3101", "Old", "Jacksonville", "Road", "Springfield,", "IL", "62704", "Phone", "(217)", "558-4490", "NOTICE", "OF", "PUBLIC", "HEARING", "\u2013", "JULY", "13,", "2021", "You", "are", "hereby", "notified", "that", "the", "Supreme", "Court", "Statutory", "Court", "Fees", "Task", "Force", "will", "hold", "a", "public", "hearing", "on", "Tuesday,", "July", "13,", "2021,", "beginning", "at", "10:00", "am,", "via", "Zoom.", "The", "Task", "Force", "seeks", "oral", "testimony", "and", "written", "comments", "on", "the", "following", "subjects:", "1.", "Fiscal", "impact", "of", "the", "Criminal", "and", "Traffic", "Assessment", "Act", "(705", "ILCS", "135/1-1", "et", "seq.),", "Section", "27.1b", "of", "the", "Clerk", "of", "Courts", "Act", "(705", "ILCS", "105/27.1b)", "and", "the", "related", "Supreme", "Court", "rules", "and", "administrative", "orders", "pertaining", "to", "fees", "and", "costs", "imposed", "on", "parties", "to", "civil,", "criminal", "and", "traffic", "proceedings", "(collectively,", "the", "\u201cCTAA", "Measures\u201d).", "2.", "Whether", "additional", "legislation,", "court", "rules", "or", "administrative", "orders", "are", "warranted", "to", "address", "issues", "that", "have", "arisen", "with", "respect", "to", "implementation", "of", "the", "CTAA", "Measures.", "3.", "Issues", "or", "proposals", "related", "to", "fees", "or", "costs", "imposed", "on", "parties", "to", "court", "proceedings", "(\u201cAssessments\u201d)", "that", "were", "not", "addressed", "by", "the", "CTAA", "Measures,", "including", "but", "not", "limited", "to:", "a.", "Assessment", "waivers", "in", "traffic", "cases;", "b.", "Assessments", "in", "juvenile", "cases;", "and", "c.", "Elimination", "of", "Assessments", "in", "criminal", "cases", "involving", "a", "sentence", "in", "excess", "of", "a", "specified", "length.", "4.", "Recommendations", "pertaining", "to", "the", "reporting", "of", "data", "concerning", "the", "imposition,", "collection", "or", "waiver", "of", "Assessments.", "Interested", "individuals", "may", "register", "to", "provide", "oral", "testimony", "at", "the", "public", "hearing", "by", "contacting", "Hayley", "Yussman", "at", "hyussman@illinoiscourts.gov", "no", "later", "than", "Tuesday,", "July", "6,", "2021.", "A", "Zoom", "link", "will", "be", "provided", "via", "email", "prior", "to", "the", "public", "hearing", "date.", "Registered", "speakers", "will", "be", "allotted", "10", "minutes", "to", "address", "the", "Task", "Force.", "Members", "of", "the", "public", "will", "be", "able", "to", "view", "the", "hearing", "online", "at", "the", "Illinois", "Supreme", "Court\u2019s", "YouTube", "page", "at", "https://www.youtube.com/c/illinoiscourts.", "Written", "comments", "may", "also", "be", "submitted", "no", "later", "than", "Tuesday,", "July", "6,", "2021,", "via", "email", "to", "Hayley", "Yussman", "at", "hyussman@illinoiscourts.gov.", "Clerks", "of", "Court", "are", "requested", "to", "post", "a", "copy", "of", "this", "notice", "in", "a", "conspicuous", "place.", "For", "more", "information", "about", "the", "Supreme", "Court", "Statutory", "Court", "Fees", "Task", "Force,", "see", "the", "administrative", "order", "creating", "the", "Task", "Force", "and", "the", "related", "press", "release", "on", "the", "Supreme", "Court\u2019s", "website."], "bbox": [[0.374412, 0.119259, 0.087055, 0.020974], [0.467647, 0.119259, 0.055829, 0.020974], [0.529608, 0.119259, 0.020417, 0.020974], [0.556176, 0.119259, 0.069342, 0.020974], [0.506569, 0.149701, 0.023811, 0.014682], [0.534696, 0.149701, 0.036148, 0.014682], [0.254216, 0.141263, 0.163203, 0.025169], [0.424804, 0.141263, 0.074384, 0.025169], [0.575196, 0.14