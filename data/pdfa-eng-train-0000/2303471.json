{"pages": [{"words": {"text": ["OF", "DIRECTOR", "WORSHIP", "MUSIC", "OVERVIEW", "New", "Life", "Presbyterian", "Church", "(PCA)", "is", "looking", "for", "a", "part-time", "Director", "of", "Worship", "Music", "who", "will", "work", "alongside", "the", "pastor", "to", "cast", "vision", "for", "the", "music", "ministry", "at", "New", "Life", "and", "to", "oversee", "and", "lead", "the", "musicians", "and", "audio/visual", "team", "for", "Sunday", "morning", "worship", "services.", "New", "Life", "is", "a", "church", "of", "200-250", "people", "who", "are", "committed", "to", "rich", "corporate", "worship,", "strong", "bonds", "of", "fellowship,", "service", "to", "our", "community,", "discipleship", "under", "the", "authority", "of", "the", "Scriptures,", "and", "evangelism", "(particularly", "through", "missions", "and", "church", "planting).", "New", "Life", "is", "located", "in", "Yorktown,", "a", "small", "community", "near", "Muncie,", "Indiana.", "The", "Muncie", "area", "is", "home", "to", "Ball", "State", "University", "and", "is", "an", "area", "that", "boasts", "of", "cultural", "and", "recreational", "activities,", "an", "affordable", "cost", "of", "living,", "and", "close", "proximity", "to", "both", "Indianapolis", "and", "Fort", "Wayne.", "This", "is", "a", "part-time", "position,", "with", "the", "hope", "of", "expanding", "to", "full-time", "as", "the", "Lord", "allows.", "We", "are", "also", "open", "to", "discussing", "ways", "in", "which", "the", "current", "position", "could", "be", "expanded", "to", "include", "other", "pastoral", "responsibilities", "that", "would", "justify", "a", "full-time", "position.", "DESCRIPTION", "REQUIREMENTS:", "Maintain", "a", "close", "walk", "with", "Jesus", "and", "live", "a", "life", "characterized", "by", "humility,", "godliness", "and", "submission", "to", "God\u2019s", "Word.", "Pray", "regularly", "for", "the", "music", "ministry.", "Plan", "the", "worship", "service", "each", "Sunday", "in", "conjunction", "with", "the", "preaching", "pastor.", "Also", "be", "available", "to", "oversee", "holiday", "services,", "such", "as", "Christmas,", "Good", "Friday", "and", "Easter.", "Attend", "and", "lead", "weekly", "rehearsals", "as", "well", "as", "Sunday", "morning", "sound", "checks", "before", "the", "worship", "services.", "Develop", "a", "plan", "for", "recruiting,", "assessing", "and", "developing", "new", "musicians.", "Cultivate", "a", "music", "ministry", "marked", "by", "technical", "proficiency,", "artistic", "quality", "and", "spiritual", "vitality", "in", "a", "way", "that", "does", "not", "draw", "attention", "to", "the", "music", "leaders,", "but", "instead", "directs", "the", "hearts", "of", "the", "congregation", "to", "their", "Creator", "and", "Redeemer.", "Strong", "interpersonal", "and", "organizational", "skills.", "Ability", "to", "function", "as", "team", "player", "who", "gets", "along", "well", "with", "others,", "but", "who", "also", "can", "enforce", "expectations", "for", "musical", "competence."], "bbox": [[0.341763, 0.097663, 0.047629, 0.029622], [0.147059, 0.091902, 0.185171, 0.036732], [0.39902, 0.091902, 0.171724, 0.036732], [0.580196, 0.091902, 0.11754, 0.036732], [0.147059, 0.159636, 0.143417, 0.022513], [0.147059, 0.186017, 0.035962, 0.015573], [0.18804, 0.186017, 0.029046, 0.015573], [0.222152, 0.186017, 0.100804, 0.015573], [0.328023, 0.186017, 0.057862, 0.015573], [0.390747, 0.186017, 0.048948, 0.015573], [0.444909, 0.186017, 0.012941, 0.015573], [0.462759, 0.186017, 0.056877, 0.015573], [0.524702, 0.186017, 0.020909, 0.015573], [0.550786, 0.186017, 0.010033, 0.015573], [0.565696, 0.186017, 0.071009, 0.015573], [0.641764, 0.186017, 0.062856, 0.015573], [0.709593, 0.186017, 0.014814, 0.015573], [0.7294, 0.186017, 0.066097, 0.015573], [0.800364, 0.186017, 0.047054, 0.015573], [0.147059, 0.204502, 0.032968, 0.015573], [0.185093, 0.204502, 0.024793, 0.015573], [0.214903, 0.204502, 0.038032, 0.015573], [0.258031, 0.204502, 0.076864, 0.0155