{"pages": [{"words": {"text": ["SCLSPR", "94.04(c)(6)", "FAMILY", "LAW", "PROCEEDINGS", "MOTIONS", "Comments", "Family", "Support", "Deputy", "Prosecuting", "Attorneys", "Commenter:", "06/10/2021", "Date", "Received:", "Comment:", "SCLSPR", "94.04(c)(6)(C)", "Family", "Law", "Proceedings", "Motions:", "This", "proposed", "rule", "change", "received", "much", "discussion.", "Positive", "feedback", "to", "avoid", "hundreds", "of", "pages", "of", "exhibits,", "but", "request", "the", "Court", "consider", "increasing", "the", "total", "number", "to", "account", "for", "pertinent", "documents", "and/or", "consider", "a", "more", "specific", "rule", "(i.e.,", "require", "a", "declaration", "with", "attachments", "or", "require", "leave", "of", "court", "or", "order", "electronic", "submission", "[via", "email", "or", "on", "a", "CD", "or", "other", "easily", "storable", "and", "reviewable", "media])", "to", "include", "screenshots", "of", "text", "messages,", "social", "media,", "or", "other", "voluminous", "exhibits.", "Family", "Support", "Deputy", "Prosecuting", "Attorneys", "Commenter:", "06/10/2021", "Date", "Received:", "Comment:", "SCLSPR94.04(c)(6)(G):", "Positive", "feedback", "-", "wise", "addition!", "Family", "Support", "Deputy", "Prosecuting", "Attorneys", "Commenter:", "06/10/2021", "Date", "Received:", "Comment:", "Including", "Exhibits", "in", "the", "page", "limits", "is", "a", "big", "change,", "and", "frankly", "will", "be", "very", "harmful", "to", "cases", "with", "high", "DV", "level", "to", "change", "this", "so.", "DV", "often", "has", "loads", "of", "documentary", "evidence,", "and", "to", "limit", "it", "will", "be", "problematic.", "C.", "Exhibits:", "Exhibits", "that", "consist", "of", "declarations", "or", "affidavits", "of", "parties", "or", "witnesses", "shall", "count", "towards", "the", "above", "page", "limit.", "Photographs,", "text", "messages,", "email,", "electronic", "communications,", "depositions", "and", "similar", "material", "shall", "count", "toward", "the", "page", "limit.", "Including", "documentary", "evidence", "in", "page", "limits", "will", "result", "in", "declarations", "being", "more", "poorly", "written,", "and", "micro", "images", "of", "texts,", "facebook", "pages,", "etc", "used", "as", "supporting", "evidence.", "Or", "edited", "versions", "of", "these", "documents", "which", "do", "not", "contain", "the", "entire", "conversation", "to", "keep", "within", "page", "limits.", "In", "high", "conflict", "cases", "that", "involve", "repeated", "verbal", "abuse,", "stalking", "behaviors,", "and", "harassment,", "electronic", "messages", "can", "support", "and", "proof", "other\u2019s", "poor", "behavior.", "Rather", "than", "page", "limit", "documentary", "evidence", "(i.e.", "police", "reports),", "a", "rule", "explaining", "best", "use", "of", "material", "would", "be", "better", "service.", "i.e.", "Photographs,", "text", "messages,", "email,", "electronic", "communications,", "depositions", "and", "similar", "material", "should", "only", "be", "used", "as", "exhibits", "if", "referenced", "and", "text", "included", "from", "these", "documents", "in", "the", "body", "of", "the", "parties", "declaration.", "All", "exhibits", "should", "be", "clearly", "printed", "and", "legible", "for", "ease", "of", "reading.", "Exhibits", "should", "not", "exceed", "15", "pages."], "bbox": [[0.058824, 0.058124, 0.075817, 0.027758], [0.140549, 0.058124, 0.115059, 0.027758], [0.261516, 0.058124, 0.078431, 0.027758], [0.345856, 0.058124, 0.048706, 0.027758], [0.40047, 0.058124, 0.151007, 0.027758], [0.557385, 0.058124, 0.103817, 0.027758], [0.058824, 0.087731, 0.092777, 0.022553], [0.156634, 0.138066, 0.047629, 0.019083], [0.208325, 0.138066, 0.058323, 0.019083], [0.270709, 0.138066, 0.053039, 0.019083], [0.32781, 0.138066, 0.086109, 0.019083], [0.417981, 0.138066, 0.071749, 0.019083], [0.058824, 0.138136, 0.093716, 0.019125], [0.174739, 0.156362, 0.086763, 0.019083], [0.058824, 0.156431, 0.03548