{"pages": [{"words": {"text": ["Changing", "the", "world", "of", "research", "evaluation:", "the", "work", "of", "the", "INORMS", "Research", "Evaluation", "Working", "Group", "*Elizabeth", "Gadd1,", "Justin", "Shearer2,", "Aline", "Pacifico", "Rodrigues3,", "Laura", "Beaupre4,", "Fang", "Zu5,", "Laura", "Himanen7,", "Baldvin", "Zarioh8,", "Hirofumi", "Seike9,", "Tanja", "Xiaoxuan", "Li5,", "Lone", "Bredahl-Jensen6,", "Strom10,", "Baron", "Wolf11", "1.", "Loughborough", "University,", "2.", "University", "of", "Melbourne,", "3.", "Sociedade", "Beneficente", "Israelita", "Brasileira", "Hospital", "Albert", "Einstein,", "4.", "University", "of", "Guelph,", "5.", "Chinese", "Academy", "of", "Sciences,", "6.", "University", "of", "Southern", "Denmark,", "7.", "Tampere", "University,", "8.", "University", "of", "Iceland,", "9.", "Kyoto", "University,", "10.", "Oslo", "Metropolitan", "University,", "11.", "University", "of", "Kentucky", "The", "INORMS", "Research", "Evaluation", "Working", "Group", "(REWG)", "was", "established", "at", "the", "2018", "INORMS", "Congress", "to", "consider", "how", "best", "to", "ensure", "that", "research", "evaluation", "is", "meaningful,", "responsible", "and", "effective.", "To", "this", "end,", "group", "members", "representing", "the", "research", "management", "societies", "that", "make", "up", "INORMS", "have", "focussed", "on", "two", "main", "work-packages.", "The", "first", "seeks", "to", "draw", "attention", "to", "the", "burgeoning", "influence", "of", "World", "University", "Rankings", "on", "the", "behaviours", "of", "universities,", "by", "developing", "a", "methodology", "for", "'rating'", "the", "Rankers", "in", "order", "to", "highlight", "some", "of", "their", "deficiencies", "and", "encourage", "better", "practices.", "The", "second", "has", "developed", "a", "five-stage", "process", "for", "evaluating", "responsibly", "called", "\u2018SCOPE\u2019,", "alongside", "a", "series", "of", "five", "arguments", "to", "persuade