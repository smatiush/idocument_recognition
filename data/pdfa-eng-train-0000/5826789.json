{"pages": [{"words": {"text": ["Nikki", "Meier,", "Livingston", "County", "Treasurer,", "has", "announced", "that", "real", "estate", "tax", "bills", "were", "mailed", "on", "Tuesday,", "June", "1,", "2021.", "A", "total", "of", "25,912", "tax", "bills", "were", "mailed.", "The", "estimated", "tax", "revenue", "to", "be", "collected", "on", "behalf", "of", "the", "203", "taxing", "bodies", "within", "the", "County", "is", "$75,313,098.58.", "The", "first", "installment", "will", "be", "due", "on", "Wednesday,", "July", "14,", "2021", "and", "the", "second", "installment", "will", "be", "due", "on", "Tuesday,", "September", "14,", "2021.", "Payments", "may", "be", "put", "in", "one", "of", "the", "two", "payment", "drop", "boxes", "at", "the", "Historic", "Courthouse,", "one", "is", "one", "the", "West", "side", "by", "the", "elevator", "and", "the", "other", "is", "on", "the", "South", "side", "at", "the", "top", "pf", "the", "stairs.", "Tax", "payers", "may", "also", "mail", "in", "payments,", "pay", "at", "most", "County", "banks,", "or", "cash", "payments", "may", "be", "made", "at", "the", "Treasurer\u2019s", "office", "in", "the", "Historic", "Courthouse", "in", "Pontiac.", "Payments", "using", "a", "credit", "or", "debit", "card", "or", "E-check", "may", "also", "be", "made", "on", "the", "County\u2019s", "website,", "www.livingstoncountyil.gov,", "on", "the", "Treasurer\u2019s", "page.", "The", "credit", "card", "companies", "do", "charge", "a", "2.25%", "convenience", "fee", "and", "the", "fee", "will", "appear", "separately", "on", "both", "your", "receipt", "and", "monthly", "statement.", "The", "fee", "for", "processing", "an", "E-check", "is", "a", "flat", "rate", "of", "$2.00.", "Payments", "paid", "after", "the", "due", "dates", "will", "result", "in", "a", "1.5%", "penalty", "per", "month", "on", "each", "installment.", "The", "late", "payment", "schedule", "is", "printed", "on", "the", "tax", "stubs", "of", "the", "bill.", "After", "September", "14th,", "payments", "will", "not", "be", "accepted", "at", "area", "banks", "and", "MUST", "be", "made", "directly", "to", "the", "Treasurer\u2019s", "office.", "Personal", "checks", "will", "not", "be", "accepted", "after", "October", "18,", "2021", "and", "payment", "after", "that", "date", "must", "be", "made", "with", "a", "cashier\u2019s", "check,", "money", "order,", "credit", "card,", "or", "cash.", "Delinquent", "Notices", "will", "be", "mailed", "on", "approximately", "October", "18,", "2021.", "The", "names", "of", "delinquent", "property", "owners", "will", "be", "published", "in", "the", "local", "newspapers", "during", "the", "week", "of", "October", "25,", "2021.", "Online", "payments", "using", "a", "credit", "or", "debit", "card", "will", "be", "accepted", "up", "through", "Friday,", "November", "5,", "2021.", "The", "annual", "tax", "sale", "will", "be", "held", "on", "Monday,", "November", "15,", "2021.", "Several", "items", "are", "printed", "on", "the", "reverse", "side", "of", "the", "tax", "bill", "which", "may", "answer", "most", "taxpayer", "questions.", "For", "further", "information", "please", "call", "between", "8:00", "A.M.", "and", "4:30", "P.M.", "Monday-Friday:", "Payment", "questions", "\u2013", "Treasurer\u2019s", "office", "-", "815-844-2306", "Assessment", "Questions/Name", "or", "Address", "Changes", "\u2013", "Assessor\u2019s", "office", "\u2013", "815-844-7214", "Tax", "rates/Prior", "Year", "Redemptions", "\u2013", "County", "Clerk", "\u2013", "815-844-2006"], "bbox": [[0.129412, 0.091169, 0.039092, 0.015573], [0.173516, 0.091169, 0.049733, 0.015573], [0.22844, 0.091169, 0.080995, 0.015573], [0.314501, 0.091169, 0.056845, 0.015573], [0.376255, 0.091169, 0.083039, 0.015573], [0.46429, 0.091169, 0.029007, 0.015573], [0.498207, 0.091169, 0.088819, 0.015573], [0.592092, 0.091169, 0.029906, 0.015573], [0.626987, 0.091169, 0.030073, 0.015573], [0.662079, 0.091169, 0.049039, 0.015573], [0.715792, 0.091169, 0.024111, 0.015573], [0.744812,