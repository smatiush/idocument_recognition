{"pages": [{"words": {"text": ["DEPARTMENT", "OF", "THE", "CHESAPEAKE", "SONS", "OF", "UNION", "VETERANS", "OF", "THE", "CIVIL", "WAR", "INCORPORATED", "BY", "ACT", "OF", "CONGRESS", "Roger", "L.", "Leturno", "Department", "Commander", "61", "Ivy", "Spring", "Lane,", "Fredericksburg,", "VA", "22406", "rleturno@msn.com", "DEPARTMENT", "ADVISORY", "2021-2022", "#1", "TO:", "Department", "of", "the", "Chesapeake", "Camp", "Commanders", "DATE:", "May", "11,", "2021", "FROM:", "Roger", "L.", "Leturno,", "Department", "Commander", "SUBJECT:", "Quarterly", "Camp", "Activity", "Reports", "Brother", "Camp", "Commanders,", "This", "advisory", "extends", "the", "guidance", "issued", "in", "Department", "Advisory", "2020-2021", "#1.", "The", "change", "in", "this", "year\u2019s", "department", "officers", "includes", "a", "\u201chandover\u201d", "in", "responsibilities.", "Department", "Senior", "Vice", "Commander", "(SVC)", "Brian", "Horgan", "now", "assumes", "Editor", "in", "Chief", "duties", "for", "our", "quarterly", "Department", "Newsletter,", "the", "Chesapeake", "Gazette.1", "I", "request", "Camp", "Commanders", "collaborate", "with", "their", "Camp", "Senior", "Vice", "Commanders", "in", "the", "preparation", "of", "quarterly", "reports", "of", "Camp", "activities", "for", "submission", "to", "the", "Department", "SVC.2", "Please", "submit", "reports", "not", "later", "than", "the", "deadlines", "established", "by", "the", "Department", "SVC", "as", "communicated", "to", "the", "Camp", "SVCs.", "The", "purpose", "of", "this", "reporting", "is", "as", "follows.", "1.", "Document", "Camp", "activities", "throughout", "the", "year", "to", "provide", "a", "basis", "for", "the", "Camps\u2019", "own", "histories.", "2.", "Provide", "material", "for", "the", "Camp", "Commanders", "to", "utilize", "when", "preparing", "their", "reports", "for", "the", "next", "Department", "Encampment.", "3.", "Give", "the", "Department", "Senior", "Vice", "Commander", "material", "for", "the", "quarterly", "newsletter.", "4.", "Summarize", "Camp", "activities", "for", "use", "by", "the", "Department", "Commander", "in", "preparing", "his", "year-end", "report", "to", "the", "National", "Office.", "Format", "for", "the", "reports", "will", "be", "MS", "Word", "compatible", "and", "may", "be", "in", "bullet", "list", "form.", "A", "few", "sentences", "are", "all", "that", "is", "required", "(e.g.,", "\u201cCamp", "observed", "Decoration", "Day", "on", "May", "30th", "by\u2026.\u201d).", "Narrative", "stories", "are", "welcome", "as", "well", "as", "photos,", "if", "available.", "Reports", "are", "requested", "regardless", "of", "the", "level", "of", "camp", "activity.", "If", "you", "have", "any", "questions,", "please", "contact", "Department", "Senior", "Vice", "Commander", "Horgan", "at", "bhorganpa@aol.com", "or", "by", "phone", "at", "440-781-6534.", "1", "C&R,", "Chapter", "II,", "Article", "VII,", "Section", "2.(b),", "\"The", "Senior", "Vice", "Department", "Commander", "shall", "promote", "Department", "activities", "in", "the", "media.", "He", "shall", "prepare", "a", "Department", "newsletter.\"", "2", "C&R,", "Chapter", "I,", "Article", "VII,", "Section", "2.(c),", "\"...The", "activities", "of", "the", "Camp", "Senior", "Vice", "Commander", "should", "include:", "...Gathering", "appropriate", "data", "about", "Camp", "activities", "and", "forwarding", "to", "the", "Department", "Senior", "Vice", "Commander.\"", "Organized", "1881", "heir", "to", "and", "representing", "the", "Grand", "Army", "of", "the", "Republic"], "bbox": [[0.322941, 0.040741, 0.131781, 0.016779], [0.459608, 0.040741, 0.025219, 0.016779], [0.489216, 0.040741, 0.038252, 0.016779], [0.532745, 0.040741, 0.127468, 0.016779], [0.187843, 0.058861, 0.068027, 0.022316], [0.26254, 0.058861, 0.03632, 0.022316], [0.30528, 0.058861, 0.087268, 0.022316], [0.398426, 0.058861, 0.142366, 0.022316], [0.547462, 0.058861, 0.03632, 0.022316], [0.589999, 0.058861, 0.055041, 0.022316], [0.6519