{"pages": [{"words": {"text": ["TDHCA", "From:", "Mailing", "List", "Emails", "To:", "Important", "Information", "for", "Providers", "about", "the", "Novel", "Coronavirus", "(COVID-19)", "Subject:", "Thursday,", "March", "05,", "2020", "1:21:18", "PM", "Date:", "In", "coordination", "with", "the", "Texas", "Department", "of", "State", "Health", "Services", "(DSHS),", "Office", "of", "the", "Governor,", "and", "the", "Texas", "Division", "of", "Emergency", "Management,", "the", "Texas", "Department", "of", "Housing", "and", "Community", "Affairs", "(TDHCA)", "is", "providing", "some", "precautionary", "strategies", "to", "help", "providers", "and", "service", "agencies", "prepare", "for", "the", "impact", "of", "the", "novel", "coronavirus", "(COVID-19)", "within", "the", "populations", "they", "serve.", "DSHS", "has", "a", "website", "specifically", "about", "COVID-19", "and", "TDHCA", "highly", "recommends", "you", "familiarize", "yourself", "with", "it.", "Here", "is", "the", "address:", "https://www.dshs.texas.gov/coronavirus/.", "Please", "call", "your", "healthcare", "professional", "if", "you,", "your", "staff,", "or", "a", "Program", "Participant:", "-", "Develops", "a", "fever;", "-", "Has", "symptoms", "of", "respiratory", "illness", "such", "as", "cough", "or", "difficulty", "breathing;", "and", "-", "Has", "been", "in", "close", "contact", "with", "a", "person", "known", "to", "have", "COVID-19,", "or", "lived", "in", "or", "have", "recently", "traveled", "to", "an", "area", "with", "ongoing", "spread", "of", "COVID-19.", "Instead", "of", "going", "straight", "to", "a", "health", "care", "facility,", "call", "first.", "Tell", "the", "healthcare", "professional", "about", "your", "recent", "travel", "or", "contact.", "Your", "healthcare", "professional", "will", "work", "with", "the", "appropriate", "public", "health", "authorities", "and", "the", "U.S.", "Center", "for", "Disease", "Control", "and", "Prevention", "(CDC)", "to", "determine", "if", "you", "(or", "the", "person", "you", "know)", "needs", "to", "be", "tested", "for", "COVID-", "19.", "The", "following", "guidelines", "are", "adapted", "from", "the", "CDC,", "and", "may", "assist", "homeless", "service", "providers:", "-", "Take", "preventive", "actions", "to", "help", "prevent", "the", "spread", "of", "respiratory", "diseases.", "Avoid", "close", "contact", "with", "people", "who", "are", "sick.", "Avoid", "touching", "your", "eyes,", "nose,", "and", "mouth.", "Clean", "and", "disinfect", "frequently", "touched", "objects", "and", "surfaces", "using", "a", "regular", "household", "cleaning", "spray", "or", "wipe.", "Wash", "your", "hands", "often", "with", "soap", "and", "water", "for", "at", "least", "20", "seconds.", "If", "soap", "and", "water", "are", "not", "readily", "available,", "use", "an", "alcohol-based", "hand", "sanitizer", "with", "at", "least", "60%", "alcohol.", "-", "Stay", "informed", "about", "the", "local", "COVID-19", "situation.", "Monitor", "the", "CDC", "website,", "the", "DSHS", "website,", "and", "your", "local", "health", "department", "for", "the", "latest", "information.", "Make", "sure", "you", "know", "about", "healthcare", "and", "public", "health", "emergency", "planning", "and", "response", "activities", "in", "your", "community.", "-", "Review", "your", "facility's", "emergency", "plan.", "-", "Communicate", "with", "your", "staff", "and", "Program", "Participants.", "Share", "information", "about", "what", "is", "currently", "known", "about", "COVID-19,", "the", "potential", "for", "surge,", "and", "your", "facility's", "preparedness", "plans.", "-", "Conduct", "an", "inventory", "of", "health", "and", "hygiene", "supplies,", "and", "order", "more", "if", "necessary.", "-", "Separate", "Program", "Participants", "with", "respiratory", "illness", "so", "they", "are", "not", "waiting", "among", "other", "persons", "seeking", "assistance.", "-------------------------------------------------", "Please", "do", "not", "reply", "to", "this", "email.", "It", "is", "from", "an", "unattended", "email", "address.", "To", "contact", "the", "Texas", "Department", "of", "Housing", "and", "Community", "Affairs,", "get", "more", "information,", "or", "view", "a", "in", "your", "Web", "browser.", "Like", "us", "on", "facebook", "(http://www.facebook.com/TDHCA)", "and", "follow", "us", "on", "slideshow", "of", "recent", "TDHCA", "activities,", "visit", "http://www.tdhca.state.tx.us/", "twitter", "(http://twitter.com/TDHCA).", "Login", "to", "your", "email", "list", "account", "to", "edit", "your", "subscription:", "http://maillist.tdhca.state.tx.us/list/login.html?lui=f9mu0g2g&mContainer=2&mOwner=G382s2w2r2p&mAddress=mailinglistemails%40TDHCA.STATE.TX.US", "Unsubscribe", "from", "this", "list:", "http://maillist.tdhca.state.tx.us/list/leave.html?", "lui=f9mu0g2g&mContainer=2&mOwner=G382s2w2r2p&mListId=HL%233&address=mailinglistemails%40TDHCA.STATE.TX.US&val=mcjik29j&d=200305B%2C1625%2C1"], "bbox": [[0.208182, 0.074344, 0.025366, 0.008582], [0.125731, 0.074375, 0.023838, 0.008601], [0.208182, 0.083089, 0.02501, 0.008582], [0.235723, 0.083089, 0.012182, 0.008582], [0.250435, 0.083089, 0.022876, 0.008582], [0.125731, 0.08312, 0.012869, 0.008601], [0.208182, 0.091834, 0.035729, 0.008582], [0.246441, 0.091834, 0.041881, 0.008582], [0.290852, 0.091834, 0.00987, 0.008582], [0.303252, 0.091834, 0.032868, 0.008582], [0.33865, 0.091834, 0.020314, 0.008582], [0.361494, 0.091834, 0.011462, 0.008582], [0.375486, 0.091834, 0.01991, 0.008582], [0.397926, 0.091834, 0.042204, 0.008582], [0.44266, 0.091834, 0.041856, 0.008582], [0.125731, 0.091865, 0.033692, 0.008601], [0.208182, 0.100579, 0.035446, 0.008582], [0.246159, 0.100579, 0.021623, 0.008582], [0.270312, 0.100579, 0.011276, 0.008582], [0.284119, 0.100579, 0.017654, 0.008582], [0.304303, 0.100579, 0.027791, 0.008582], [0.334624, 0.100579, 0.010686, 0.008582], [0.125731, 0.10061, 0.02206, 0.008601], [0.124114, 0.131224, 0.008754, 0.010833], [0.135495, 0.1312